{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/optcg-media/:path*",
      "destination": "https://optcgapi.com/media/:path*"
    },
    {
      "source": "/opcg-api/:path*",
      "destination": "https://optcgapi.com/:path*"
    },
    {
      "source": "/((?!api/)(?!opcg-api/).*)",
      "destination": "/index.html"
    }
  ]
}
